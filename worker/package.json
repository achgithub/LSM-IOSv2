{
  "name": "lsm-worker",
  "version": "2.0.0",
  "private": true,
  "description": "LSM v2 Cloudflare Worker — regional-shard sports-data + cloud-backed game state (games/players/picks/predictions) and the submission queue. One deployment per region shard (--env uk | eu); leagues are rows in D1, not per-env config.",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "volta": {
    "node": "22.22.3",
    "pnpm": "11.2.2"
  },
  "scripts": {
    "dev": "wrangler dev --env uk",
    "deploy:uk": "wrangler deploy --env uk",
    "deploy:eu": "wrangler deploy --env eu",
    "types": "wrangler types --env uk",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:apply:uk": "wrangler d1 execute lsm-uk-db --remote --file=./schema.sql",
    "db:apply:uk:local": "wrangler d1 execute lsm-uk-db --local --file=./schema.sql",
    "db:apply:eu": "wrangler d1 execute lsm-eu-db --remote --file=./schema.sql",
    "db:apply:eu:local": "wrangler d1 execute lsm-eu-db --local --file=./schema.sql"
  },
  "dependencies": {
    "@levischuck/tiny-cbor": "^0.3.4",
    "@peculiar/x509": "^1.14.3",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^4.1.9",
    "wrangler": "^4.100.0"
  }
}
