    "Selected players win; everyone else is eliminated and the game ends.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die ausgewählten Spieler gewinnen; alle anderen scheiden aus und das Spiel endet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los jugadores seleccionados ganan; el resto queda eliminado y la partida termina."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les joueurs sélectionnés gagnent ; tous les autres sont éliminés et la partie se termine."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I giocatori selezionati vincono; tutti gli altri sono eliminati e la partita finisce."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De geselecteerde spelers winnen; de rest valt af en het spel eindigt."
          }
        }
      }
    },
    "Send the fixtures card so players know the matches to choose from.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sende die Spielplan-Karte, damit die Spieler wissen, aus welchen Spielen sie wählen können."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía la tarjeta de partidos para que los jugadores sepan entre qué partidos elegir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoie la carte des matchs pour que les joueurs sachent parmi quels matchs choisir."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Invia la scheda partite così i giocatori sanno tra quali partite scegliere."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stuur de wedstrijdkaart zodat spelers weten uit welke wedstrijden ze kunnen kiezen."
          }
        }
      }
    },
    "Send the picks summary so everyone sees who picked what.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sende die Tipp-Übersicht, damit alle sehen, wer was getippt hat."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía el resumen de selecciones para que todos vean quién eligió qué."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoie le récapitulatif des choix pour que chacun voie qui a choisi quoi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Invia il riepilogo delle scelte così tutti vedono chi ha scelto cosa."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stuur het keuzeoverzicht zodat iedereen ziet wie wat koos."
          }
        }
      }
    },
    "Send the results card — who survived to round 2. That's the loop! Carry on as normal from here.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sende die Ergebnis-Karte – wer in Runde 2 kommt. Das ist der Ablauf! Mach ab hier wie gewohnt weiter."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía la tarjeta de resultados: quién pasa a la ronda 2. ¡Ese es el ciclo! A partir de aquí, sigue como siempre."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoie la carte des résultats — qui passe en manche 2. C’est la boucle ! Continue normalement à partir d’ici."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Invia la scheda risultati: chi passa al turno 2. Questo è il ciclo! Da qui prosegui come al solito."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stuur de resultatenkaart — wie door is naar ronde 2. Dat is de cyclus! Ga vanaf hier gewoon door."
          }
        }
      }
    },
