    "This permanently deletes the game and its history — on this device and in the cloud, including any player picks or predictions submitted through their links.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies löscht das Spiel und seinen Verlauf endgültig — auf diesem Gerät und in der Cloud, einschließlich aller über Links eingereichten Spieler-Tipps oder Vorhersagen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina permanentemente la partida y su historial — en este dispositivo y en la nube, incluidas las selecciones o predicciones enviadas por los jugadores a través de sus enlaces."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprime définitivement la partie et son historique — sur cet appareil et dans le cloud, y compris les choix ou prédictions des joueurs soumis via leurs liens."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo elimina definitivamente la partita e la sua cronologia — su questo dispositivo e nel cloud, incluse le scelte o i pronostici dei giocatori inviati tramite i loro link."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit verwijdert het spel en de geschiedenis ervan permanent — op dit apparaat en in de cloud, inclusief eventuele keuzes of voorspellingen van spelers die via hun links zijn ingediend."
          }
        }
      }
    },
    "This permanently deletes these games and their history — on this device and in the cloud, including any player picks or predictions submitted through their links.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies löscht diese Spiele und ihren Verlauf endgültig — auf diesem Gerät und in der Cloud, einschließlich aller über Links eingereichten Spieler-Tipps oder Vorhersagen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina permanentemente estas partidas y su historial — en este dispositivo y en la nube, incluidas las selecciones o predicciones enviadas por los jugadores a través de sus enlaces."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprime définitivement ces parties et leur historique — sur cet appareil et dans le cloud, y compris les choix ou prédictions des joueurs soumis via leurs liens."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo elimina definitivamente queste partite e la loro cronologia — su questo dispositivo e nel cloud, incluse le scelte o i pronostici dei giocatori inviati tramite i loro link."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit verwijdert deze spellen en hun geschiedenis permanent — op dit apparaat en in de cloud, inclusief eventuele keuzes of voorspellingen van spelers die via hun links zijn ingediend."
          }
        }
      }
    },
