    "Closing this round will score every prediction. This can't be changed afterwards, so make sure each result is final and entered correctly.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beim Schließen der Runde werden alle Vorhersagen gewertet. Das lässt sich danach nicht mehr ändern – stelle daher sicher, dass jedes Ergebnis endgültig und korrekt eingegeben ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al cerrar la ronda se puntuarán todas las predicciones. Esto no se puede cambiar después, así que asegúrate de que cada resultado sea definitivo y esté introducido correctamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La clôture de cette manche attribue les points de toutes les prédictions. C'est irréversible, alors vérifie que chaque résultat est définitif et correctement saisi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chiudendo il turno verranno assegnati i punti a tutte le previsioni. L'operazione non è reversibile, quindi assicurati che ogni risultato sia definitivo e inserito correttamente."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als je deze ronde sluit, worden alle voorspellingen gescoord. Dit kan daarna niet meer worden gewijzigd, dus controleer of elke uitslag definitief en juist is ingevoerd."
          }
        }
      }
    },
