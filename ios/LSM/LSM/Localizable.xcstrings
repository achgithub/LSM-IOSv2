    "No activity for 45 days — your cloud data will be deleted in 15 days if no round is opened.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Seit 45 Tagen keine Aktivität — deine Cloud-Daten werden in 15 Tagen gelöscht, wenn keine Runde geöffnet wird."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin actividad durante 45 días — tus datos en la nube se eliminarán en 15 días si no se abre ninguna ronda."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune activité depuis 45 jours — tes données cloud seront supprimées dans 15 jours si aucune manche n'est ouverte."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessuna attività da 45 giorni — i tuoi dati cloud verranno eliminati tra 15 giorni se non viene aperto nessun turno."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "45 dagen geen activiteit — je clouddata worden over 15 dagen verwijderd als er geen ronde wordt geopend."
          }
        }
      }
    },
