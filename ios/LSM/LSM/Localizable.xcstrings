    "Add the final scores for each fixture, then close the matchday to award points.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Trage die Endergebnisse für jedes Spiel ein und schließe dann den Spieltag ab, um Punkte zu vergeben."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Introduce el resultado final de cada partido y luego cierra la jornada para otorgar puntos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Saisis le score final de chaque match, puis clôture la journée pour attribuer les points."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inserisci il risultato finale di ogni partita, poi chiudi la giornata per assegnare i punti."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voer de eindstand van elke wedstrijd in en sluit dan de speelronde af om punten toe te kennen."
          }
        }
      }
    },
    "Add the people who'll play, and optionally group them (e.g. \"Office\"). This is your reusable roster.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge die Personen hinzu, die mitspielen, und gruppiere sie optional (z. B. „Büro“). Das ist deine wiederverwendbare Liste."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade a las personas que jugarán y, opcionalmente, agrúpalas (p. ej. «Oficina»). Esta es tu lista reutilizable."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoute les personnes qui joueront et, si tu veux, regroupe-les (p. ex. « Bureau »). C’est ta liste réutilisable."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi le persone che giocheranno e, se vuoi, raggruppale (es. «Ufficio»). Questo è il tuo elenco riutilizzabile."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voeg de mensen toe die meespelen en groepeer ze eventueel (bijv. ‘Kantoor’). Dit is je herbruikbare lijst."
          }
        }
      }
    },
