          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comparte este enlace y el PIN juntos (p. ej. en una tarjeta): quien tenga ambos podrá ver los resultados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
