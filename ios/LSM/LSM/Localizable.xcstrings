    "You can enable %lld leagues on the %@ plan.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit dem %2$@-Tarif kannst du %1$lld Ligen aktivieren."
          }
        },
        "es": {
          "stringUnit": {
