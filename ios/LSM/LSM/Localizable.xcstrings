    "Each prediction earns the single highest rung it qualifies for. A correct non-exact draw lands on Goal difference, not Result.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jede Vorhersage erhält nur die höchste Stufe, für die sie qualifiziert. Ein richtiges, nicht exaktes Unentschieden fällt unter Tordifferenz, nicht Ergebnis."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada predicción obtiene únicamente el nivel más alto para el que califica. Un empate correcto pero no exacto cuenta como Diferencia de goles, no como Resultado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaque prédiction ne rapporte que le niveau le plus élevé auquel elle est éligible. Un match nul correct mais non exact relève de la Différence de buts, pas du Résultat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ogni pronostico ottiene solo il livello più alto per cui si qualifica. Un pareggio corretto ma non esatto rientra nella Differenza reti, non nel Risultato."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Elke voorspelling verdient alleen het hoogste niveau waarvoor ze in aanmerking komt. Een juist maar niet exact gelijkspel valt onder Doelsaldo, niet Resultaat."
          }
        }
      }
    },
    "Each unassigned player gets the bottom-of-table team still available to them.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeder nicht zugewiesene Spieler erhält die in der Tabelle am tiefsten stehende, noch verfügbare Mannschaft."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada jugador sin asignar recibe el equipo más bajo de la tabla que aún tenga disponible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaque joueur non attribué reçoit l’équipe la plus basse au classement encore disponible pour lui."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
