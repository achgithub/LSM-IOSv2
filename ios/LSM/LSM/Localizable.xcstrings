    "Names are checked against this game's league(s); if a real team is ever added with the same name, this entry is replaced automatically.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Namen werden mit der/den Liga(en) dieses Spiels abgeglichen; wird jemals ein echtes Team mit demselben Namen hinzugefügt, wird dieser Eintrag automatisch ersetzt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los nombres se comparan con las ligas de esta partida; si alguna vez se añade un equipo real con el mismo nombre, esta entrada se reemplaza automáticamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les noms sont comparés aux ligues de cette partie ; si une vraie équipe portant le même nom est un jour ajoutée, cette entrée est remplacée automatiquement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I nomi vengono confrontati con i campionati di questa partita; se viene aggiunta una squadra reale con lo stesso nome, questa voce viene sostituita automaticamente."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Namen worden vergeleken met de competitie(s) van dit spel; als er ooit een echt team met dezelfde naam wordt toegevoegd, wordt dit item automatisch vervangen."
          }
        }
      }
    },
