    "Players submit their predicted scores via the public link. You can also enter predictions on their behalf.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spieler senden ihre vorhergesagten Ergebnisse über den öffentlichen Link. Du kannst Vorhersagen auch für sie eingeben."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los jugadores envían sus resultados predichos a través del enlace público. También puedes introducir predicciones en su nombre."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les joueurs envoient leurs scores prédits via le lien public. Tu peux aussi saisir des prédictions en leur nom."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I giocatori inviano i risultati pronosticati tramite il link pubblico. Puoi anche inserire i pronostici per loro conto."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spelers dienen hun voorspelde uitslagen in via de openbare link. Je kunt ook zelf voorspellingen namens hen invoeren."
          }
        }
      }
