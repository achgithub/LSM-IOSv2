            "state": "translated",
            "value": "Resultaten van server ophalen"
          }
        }
      }
    },
    "Pull the results (or set them), then close the round to work out who's out.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lade die Ergebnisse (oder trage sie ein) und schließe dann die Runde, um zu sehen, wer ausscheidet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Obtén los resultados (o introdúcelos) y luego cierra la ronda para ver quién queda fuera."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Récupère les résultats (ou saisis-les), puis clôture la manche pour voir qui est éliminé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scarica i risultati (o inseriscili), poi chiudi il turno per vedere chi è fuori."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Haal de resultaten op (of voer ze in) en sluit dan de ronde om te bepalen wie afvalt."
          }
        }
      }
    },
