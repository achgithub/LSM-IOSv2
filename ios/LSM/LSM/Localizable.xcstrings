    "Still in — pick again": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch dabei – erneut tippen"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sigue en juego: vuelve a elegir"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Encore en lice — choisis à nouveau"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ancora in gioco: scegli di nuovo"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nog in de race — kies opnieuw"
          }
        }
      }
    },
    "Still waiting on players? You don't have to do this now — close the wizard and come back any time by swiping the game to the right. It picks up right here.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wartest du noch auf Spieler? Du musst das nicht jetzt machen – schließe den Assistenten und komm jederzeit zurück, indem du das Spiel nach rechts wischst. Er macht genau hier weiter."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Todavía esperas a algún jugador? No tienes que hacerlo ahora: cierra el asistente y vuelve cuando quieras deslizando la partida hacia la derecha. Continuará justo aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu attends encore des joueurs ? Pas besoin de le faire maintenant — ferme l'assistant et reviens quand tu veux en faisant glisser la partie vers la droite. Il reprendra ici même."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Stai ancora aspettando dei giocatori? Non devi farlo ora: chiudi la procedura guidata e torna quando vuoi scorrendo la partita verso destra. Riprenderà proprio da qui."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wacht je nog op spelers? Je hoeft dit nu niet te doen — sluit de wizard en kom op elk moment terug door het spel naar rechts te vegen. Hij gaat precies hier verder."
          }
        }
      }
    },
