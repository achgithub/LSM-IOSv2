    "Last Man Standing eliminates a player on a wrong pick. Predictor scores every player's predicted scoreline each round — no elimination.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Last Man Standing scheidet einen Spieler bei einem falschen Tipp aus. Predictor bewertet jede Runde die vorhergesagten Ergebnisse aller Spieler — kein Ausscheiden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Last Man Standing elimina a un jugador si falla su selección. Predictor puntúa el resultado predicho por cada jugador en cada ronda: sin eliminación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Last Man Standing élimine un joueur en cas de mauvais choix. Predictor note le score prédit par chaque joueur à chaque manche — sans élimination."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Last Man Standing elimina un giocatore in caso di pronostico errato. Predictor assegna punti al risultato pronosticato da ogni giocatore ogni turno — nessuna eliminazione."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Last Man Standing elimineert een speler bij een verkeerde keuze. Predictor beoordeelt elke ronde de voorspelde uitslag van elke speler — geen uitsluiting."
          }
        }
      }
    },
