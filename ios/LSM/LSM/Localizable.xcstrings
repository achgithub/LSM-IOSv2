    "Face to face with this player? Show them this screen and let them scan it with their own camera.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bist du mit diesem Spieler persönlich zusammen? Zeig ihm diesen Bildschirm und lass ihn mit seiner eigenen Kamera scannen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Estás cara a cara con este jugador? Muéstrale esta pantalla y deja que la escanee con su propia cámara."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Face à face avec ce joueur ? Montre-lui cet écran et laisse-le le scanner avec son propre appareil photo."
          }
        },
        "it": {
          "stringUnit": {
