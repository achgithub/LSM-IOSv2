          "stringUnit": {
            "state": "translated",
            "value": "Je kunt %lld competities inschakelen met het %@-abonnement."
          }
        }
      }
    },
    "You're added to games you create, and your pick is always shown on shared summary cards.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du wirst zu den von dir erstellten Spielen hinzugefügt, und dein Tipp erscheint immer auf geteilten Übersichtskarten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te añadimos a las partidas que creas, y tu selección siempre aparece en las tarjetas de resumen compartidas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu es ajouté aux parties que tu crées, et ton choix apparaît toujours sur les cartes récapitulatives partagées."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vieni aggiunto alle partite che crei e la tua scelta appare sempre sulle schede riepilogative condivise."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je wordt toegevoegd aan spellen die je maakt, en je keuze staat altijd op gedeelde samenvattingskaarten."
          }
        }
      }
    },
    "You're not playing this game — no ⚑ on cards.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du spielst dieses Spiel nicht mit – kein ⚑ auf den Karten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No juegas esta partida: sin ⚑ en las tarjetas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu ne joues pas à cette partie — pas de ⚑ sur les cartes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non giochi questa partita: nessuna ⚑ sulle schede."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je speelt dit spel niet mee — geen ⚑ op kaarten."
          }
        }
      }
    },
    "You're playing — your pick shows on shared cards (⚑).": {
      "extractionState": "manual",
