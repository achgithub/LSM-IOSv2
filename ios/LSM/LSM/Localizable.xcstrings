          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Speler nummer %lld is meer dan eens doelwit — Hits moeten verschillende tegenstanders raken."
          }
        }
      }
    },
    "Found %lld of %lld fixtures — check every fixture number is included.": {
