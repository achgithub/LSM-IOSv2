    "Other players are pre-filled. Enter a score for the first fixture (try 2–0), then tap Done ↑.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für die anderen Spieler ist bereits ausgefüllt. Gib für das erste Spiel ein Ergebnis ein (versuch's mit 2:0) und tippe dann oben auf Fertig."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los demás jugadores ya están rellenados. Introduce un resultado para el primer partido (prueba 2-0) y luego toca Listo arriba."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les autres joueurs sont déjà remplis. Saisis un score pour le premier match (essaie 2-0), puis appuie sur Terminé en haut."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli altri giocatori sono già compilati. Inserisci un risultato per la prima partita (prova 2-0), poi tocca Fatto in alto."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De andere spelers zijn al ingevuld. Voer een uitslag in voor de eerste wedstrijd (probeer 2-0) en tik dan hierboven op Klaar."
          }
        }
      }
    },
    "Only tap this if you were expecting it — check with your manager first if you're not sure.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe hier nur, wenn du das erwartet hast — frag im Zweifel zuerst deinen Manager."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca esto solo si lo esperabas — consulta primero con tu mánager si no estás seguro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "N'appuie ici que si tu t'y attendais — vérifie d'abord auprès de ton manager en cas de doute."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca qui solo se te lo aspettavi — in caso di dubbio, controlla prima con il tuo manager."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tik hier alleen op als je dit verwachtte — vraag bij twijfel eerst je manager."
          }
        }
