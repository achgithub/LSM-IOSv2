    "Disabling %@ removes its data from this device and deletes %lld games that use it — here and in the cloud.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Disabling %1$@ removes its data from this device and deletes %2$lld games that use it — here and in the cloud."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beim Deaktivieren von %@ werden dessen Daten von diesem Gerät entfernt und %lld Spiele gelöscht, die sie verwenden — hier und in der Cloud."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desactivar %@ elimina sus datos de este dispositivo y borra %lld partidas que la usan, aquí y en la nube."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Désactiver %@ supprime ses données de cet appareil et efface %lld parties qui l'utilisent — ici et dans le cloud."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Disattivare %@ elimina i suoi dati da questo dispositivo e cancella %lld partite che la utilizzano — qui e sul cloud."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ uitschakelen verwijdert de gegevens van dit apparaat en verwijdert %lld spellen die het gebruiken — hier en in de cloud."
          }
        }
      }
    },
    "Disabling %@ removes its data from this device and deletes %lld games that use it.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beim Deaktivieren von %@ werden dessen Daten von diesem Gerät entfernt und %lld Spiele gelöscht, die sie verwenden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desactivar %@ elimina sus datos de este dispositivo y borra %lld partidas que la usan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Désactiver %@ supprime ses données de cet appareil et supprime %lld parties qui l’utilisent."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Disattivare %@ rimuove i suoi dati da questo dispositivo ed elimina %lld partite che la usano."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ uitschakelen verwijdert de gegevens van dit apparaat en wist %lld spellen die het gebruiken."
          }
        }
      }
    },
