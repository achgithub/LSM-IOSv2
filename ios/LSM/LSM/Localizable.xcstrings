    "Player number %lld is targeted more than once — Hits must target different opponents.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spielernummer %lld wird mehrmals als Ziel gewählt — Hits müssen unterschiedliche Gegner treffen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El jugador número %lld es objetivo más de una vez — los Hits deben apuntar a rivales distintos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
