    "Subscribing or restoring instantly covers all your current leagues — nothing is removed either way.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Abo abzuschließen oder wiederherzustellen deckt sofort alle deine aktuellen Ligen ab — in beiden Fällen wird nichts entfernt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Suscribirte o restaurar cubre al instante todas tus ligas actuales — en ambos casos no se elimina nada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "S'abonner ou restaurer couvre instantanément toutes tes ligues actuelles — rien n'est retiré dans les deux cas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Abbonarsi o ripristinare copre subito tutti i tuoi campionati attuali — in entrambi i casi non viene rimosso nulla."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Abonneren of herstellen dekt direct al je huidige competities — in beide gevallen wordt er niets verwijderd."
          }
        }
      }
    },
    "These players have already used every team in the selected fixtures. Add more fixtures, or remove one of the ones above, before opening.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Spieler haben bereits jedes Team in den ausgewählten Spielen verwendet. Füge weitere Spiele hinzu oder entferne eines der oben genannten, bevor du öffnest."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estos jugadores ya han usado todos los equipos de los partidos seleccionados. Añade más partidos o quita uno de los de arriba antes de abrir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ces joueurs ont déjà utilisé toutes les équipes des matchs sélectionnés. Ajoute d'autres matchs, ou retire l'un de ceux ci-dessus, avant d'ouvrir."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questi giocatori hanno già usato tutte le squadre delle partite selezionate. Aggiungi altre partite, oppure rimuovi una di quelle sopra, prima di aprire."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze spelers hebben al elk team in de geselecteerde wedstrijden gebruikt. Voeg meer wedstrijden toe, of verwijder er een van hierboven, voordat je opent."
          }
        }
      }
    },
