    "Removes %@ from this device and permanently deletes %lld games that use it — here and in the cloud.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Removes %1$@ from this device and permanently deletes %2$lld games that use it — here and in the cloud."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entfernt %@ von diesem Gerät und löscht dauerhaft %lld Spiele, die sie verwenden — hier und in der Cloud."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina %@ de este dispositivo y borra permanentemente %lld partidas que la usan, aquí y en la nube."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprime %@ de cet appareil et efface définitivement %lld parties qui l'utilisent — ici et dans le cloud."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuove %@ da questo dispositivo ed elimina definitivamente %lld partite che la utilizzano — qui e sul cloud."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwijdert %@ van dit apparaat en verwijdert permanent %lld spellen die het gebruiken — hier en in de cloud."
          }
        }
      }
    },
