          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Da a cada jugador un enlace privado para que envíe sus selecciones. Tú apruebas antes de que se publiquen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
