          "stringUnit": {
            "state": "translated",
            "value": "Deactiveert de PWA-inzendlink volledig, in elk spel waarin deze speler zit. Er is een nieuwe link nodig voordat opnieuw kan worden ingediend."
          }
        }
      }
    },
