    "This resets the round so you can reselect fixtures. Any picks already made are cleared. This can't be undone.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies setzt die Runde zurück, damit du die Spiele neu auswählen kannst. Bereits getroffene Tipps werden gelöscht. Das kann nicht rückgängig gemacht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto reinicia la ronda para que puedas volver a elegir los partidos. Las selecciones ya hechas se borran. Esto no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela réinitialise la manche pour que tu puisses resélectionner les matchs. Les choix déjà faits sont effacés. Action irréversible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo azzera il turno così puoi riselezionare le partite. Le scelte già fatte vengono cancellate. L'operazione non può essere annullata."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit zet de ronde terug zodat je de wedstrijden opnieuw kunt kiezen. Reeds gemaakte keuzes worden gewist. Dit kan niet ongedaan worden gemaakt."
          }
        }
      }
    },
    "This resets the round so you can reselect fixtures. Any predictions already entered are cleared. This can't be undone.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies setzt die Runde zurück, damit du Spiele neu auswählen kannst. Bereits eingegebene Vorhersagen werden gelöscht. Das kann nicht rückgängig gemacht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto reinicia la ronda para que puedas volver a seleccionar los partidos. Se borrarán las predicciones ya introducidas. Esto no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela réinitialise la manche pour permettre de resélectionner les matchs. Les prédictions déjà saisies sont effacées. Cette action est irréversible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo azzera il turno per permetterti di riselezionare le partite. I pronostici già inseriti vengono eliminati. Questa azione non può essere annullata."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit reset de ronde zodat je wedstrijden opnieuw kunt selecteren. Al ingevoerde voorspellingen worden gewist. Dit kan niet ongedaan worden gemaakt."
          }
        }
      }
    },
