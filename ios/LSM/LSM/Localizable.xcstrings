    "Record each player's team, then Auto-Assign anyone who didn't reply in time.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfasse die Mannschaft jedes Spielers und weise allen, die nicht rechtzeitig geantwortet haben, automatisch eine zu."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra el equipo de cada jugador y luego asigna automáticamente a quien no respondió a tiempo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Note l’équipe de chaque joueur, puis attribue automatiquement à ceux qui n’ont pas répondu à temps."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra la squadra di ogni giocatore, poi assegna automaticamente a chi non ha risposto in tempo."
          }
        },
