    "Publishing generates a link and a 6-digit PIN, both yours to share with the group.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beim Veröffentlichen werden ein Link und eine 6-stellige PIN erstellt, die du mit der Gruppe teilen kannst."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al publicar se genera un enlace y un PIN de 6 dígitos, ambos para compartir con el grupo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La publication génère un lien et un code PIN à 6 chiffres, tous deux à partager avec le groupe."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La pubblicazione genera un link e un PIN di 6 cifre, entrambi da condividere con il gruppo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Publiceren genereert een link en een 6-cijferige pincode, beide om te delen met de groep."
          }
        }
      }
    },
    "Pull people from your roster into this game — you need at least two to play.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hol Personen aus deiner Liste in dieses Spiel – du brauchst mindestens zwei zum Spielen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Trae personas de tu lista a esta partida: necesitas al menos dos para jugar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoute des personnes de ta liste à cette partie — il en faut au moins deux pour jouer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Porta persone dal tuo elenco in questa partita: ne servono almeno due per giocare."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Haal mensen uit je lijst naar dit spel — je hebt er minstens twee nodig om te spelen."
          }
        }
      }
    },
    "Pull results from server": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ergebnisse vom Server laden"
          }
