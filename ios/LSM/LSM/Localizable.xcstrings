    "Switches from %@ to %@, deleting %lld games that use the old league — here and in the cloud.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Switches from %1$@ to %2$@, deleting %3$lld games that use the old league — here and in the cloud."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wechselt von %@ zu %@ und löscht %lld Spiele, die die alte Liga verwenden — hier und in der Cloud."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia de %@ a %@, eliminando %lld partidas que usan la liga anterior, aquí y en la nube."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Passe de %@ à %@, en supprimant %lld parties utilisant l'ancienne ligue — ici et dans le cloud."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Passa da %@ a %@, eliminando %lld partite che usano la vecchia lega — qui e sul cloud."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wisselt van %@ naar %@, waarbij %lld spellen die de oude competitie gebruiken worden verwijderd — hier en in de cloud."
          }
        }
      }
    },
    "Switches from %@ to %@, deleting %lld games that use the old league.": {
